---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import {
  SITE,
  SHOW_RESOURCES,
  ABOUT_PARAGRAPHS,
  EDUCATION,
  CERTS,
  fmtDate,
  withBase,
} from "../lib/site.ts";
import { pdfUrl } from "../lib/resources.ts";

// Resources are a content collection so they're editable in the CMS. A PDF-backed
// resource opens in the on-site reader; an external one links straight out.
const resources = (await getCollection("resources")).sort(
  (a, b) => a.data.order - b.data.order,
);
const resourceLink = (r: (typeof resources)[number]) =>
  pdfUrl(r.data.file)
    ? { href: withBase(`/resources/${r.id}`), external: false }
    : { href: r.data.url ?? "#", external: true };

// Unfilled "[bracketed]" placeholders are hidden rather than printed.
const isPlaceholder = (s: string) => !s || s.trim().startsWith("[");
const about = ABOUT_PARAGRAPHS.filter((p) => !isPlaceholder(p));

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Derive a one-line excerpt from a post's body when no clean description is set.
function excerpt(post: (typeof posts)[number]): string {
  const desc = post.data.description ?? "";
  if (desc && !desc.startsWith("[")) return desc;
  // First plain-prose line: skip headings, images, tables, code, quotes,
  // list markers, bold-only lines, and box-drawing / ASCII-art rows.
  const line = (post.body ?? "")
    .split("\n")
    .map((l) => l.trim())
    .find((l) => /^[A-Za-z(“"']/.test(l) && !l.startsWith("**"));
  if (!line) return "";
  const clean = line.replace(/[*_`]/g, "");
  return clean.length > 150 ? clean.slice(0, 147).trimEnd() + "…" : clean;
}

const socials = [
  { label: "github", href: SITE.links.github },
  { label: "x", href: SITE.links.x },
  { label: "email", href: SITE.links.email },
  { label: "rss", href: SITE.links.rss },
];
---

<Base ogType="profile">
  <div class="wrap">
    <!-- ══ Hero ══ -->
    <section class="hero" id="top">
      <div class="avatar">avatar.jpg</div>
      <p class="whoami">$ whoami</p>
      <h1>{SITE.name}</h1>
      <p class="tagline">{SITE.tagline}</p>
      <div class="cta-row">
        <a class="cta filled" href="#contact">get in touch</a>
        <a class="cta outline" href="#projects">see work</a>
      </div>
    </section>

    <!-- ══ About ══ -->
    {
      about.length > 0 && (
        <section class="block" id="about">
          <h2 class="eyebrow">// about</h2>
          <div class="prose">
            {about.map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </section>
      )
    }

    <!-- ══ Education ══ -->
    <section class="block" id="education">
      <h2 class="eyebrow">// education <span class="count">{EDUCATION.length}</span></h2>
      {
        EDUCATION.map((e) => (
          <div class="edu">
            <span class="e-main">
              <span class="e-degree">{e.degree}</span>
              <span class="e-inst"> — {e.institution}</span>
            </span>
            <span class="e-meta">
              {e.years}
              <span class="e-result">{e.result}</span>
            </span>
          </div>
        ))
      }
      {
        !isPlaceholder(CERTS) && (
          <div class="certs">
            <span class="k">certs</span>
            <span>{CERTS}</span>
          </div>
        )
      }
    </section>

    <!-- ══ Writing ══ -->
    <section class="block" id="writing">
      <h2 class="eyebrow">// writing <span class="count">{posts.length} posts</span></h2>
      {
        posts.map((p) => (
          <a class="post" href={withBase(`/blog/${p.id}`)}>
            <span class="post-date">{fmtDate(p.data.date)}</span>
            <h3>{p.data.title}</h3>
            <p class="excerpt">{excerpt(p)}</p>
            <div class="tags">
              {p.data.tags.map((t) => (
                <span class="chip">{t}</span>
              ))}
            </div>
          </a>
        ))
      }
    </section>

    <!-- ══ Projects ══ -->
    <section class="block" id="projects">
      <h2 class="eyebrow">// projects <span class="count">{projects.length}</span></h2>
      <div class="card-grid">
        {
          projects.map((p) => (
            <a class="card" href={withBase(`/projects/${p.id}`)}>
              <div class="card-top">
                <h3>{p.data.title}</h3>
                <span class="arrow">↗</span>
              </div>
              <p class="card-desc">{p.data.pitch}</p>
              <div class="tags">
                {p.data.stack.slice(0, 4).map((s) => (
                  <span class="chip">{s}</span>
                ))}
              </div>
              <div style="margin-top:10px">
                <span class:list={["status", p.data.status === "SHIPPED" && "shipped"]}>
                  {p.data.status} · {p.data.year}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ══ Resources ══ -->
    {
      SHOW_RESOURCES && (
        <section class="block" id="resources">
          <h2 class="eyebrow">// resources <span class="count">{resources.length}</span></h2>
          {resources.map((r) => {
            const link = resourceLink(r);
            return (
              <a
                class="resource"
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener" : undefined}
              >
                <span class="kind">{r.data.kind}</span>
                <span class="r-main">
                  <span class="r-title">{r.data.title}</span>
                  <span class="r-note"> — {r.data.note}</span>
                </span>
                <span class="r-arrow">{link.external ? "↗" : "read →"}</span>
              </a>
            );
          })}
        </section>
      )
    }

    <!-- ══ Contact ══ -->
    <section class="block" id="contact">
      <h2 class="eyebrow">// contact</h2>
      <p class="contact-blurb">{SITE.contactBlurb}</p>
      <div class="pill-row">
        {
          socials.map((s) => (
            <a
              class="pill"
              href={s.href}
              target={s.href.startsWith("http") ? "_blank" : undefined}
              rel="noopener"
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
