---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { readingTime, fmtDate, withBase } from "../../lib/site.ts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const withMeta = posts.map((p) => ({ ...p, minutes: readingTime(p.body ?? "") }));

const tagCount = (t: string) => posts.filter((p) => p.data.tags.includes(t as never)).length;
const avg = Math.round(withMeta.reduce((s, p) => s + p.minutes, 0) / Math.max(1, posts.length));
const statsLine = `${posts.length} ENTRIES · AI(${tagCount("AI")}) TECH(${tagCount("TECH")}) MARKETS(${tagCount("MARKETS")}) RESEARCH(${tagCount("RESEARCH")}) · AVG ${avg} MIN`;
---

<Base
  active="blog"
  title="Blog — InsiderByHasham"
  description="Briefing index — research notes on AI, tech, and the markets."
>
  <div class="pt-28" style="min-height: 70vh;">
    <section class="panel index-hero">
      <div class="prompt"><span class="ps1">hasham@insider:~$</span> tail -f ./blog --index</div>
      <div class="headline">
        <h1>BRIEFING.INDEX</h1>
        <span class="stats-line">{statsLine}</span>
      </div>
    </section>

    <div class="panel attached">
      <div class="tbl-head grid-blog">
        <span>DATE</span><span>TITLE</span><span class="col-tags">TAGS</span><span
          class="right col-min">MIN</span
        ><span class="right">ACTION</span>
      </div>
      {
        withMeta.map((p) => (
          <a class="tbl-row grid-blog" href={withBase(`/blog/${p.id}`)}>
            <span class="dim">{fmtDate(p.data.date)}</span>
            <span>
              <span class="name">{p.data.title}</span>
              {p.data.pinned && <span class="pinned-chip">PINNED</span>}
            </span>
            <span class="dim col-tags">{p.data.tags.join(" · ")}</span>
            <span class="right dim col-min">{p.minutes}</span>
            <span class="open-link">read ↗</span>
          </a>
        ))
      }
    </div>

    <section class="panel subscribe">
      <div class="label">▌SUBSCRIBE.SH</div>
      <div class="blurb">get the next briefing first — no spam, unsubscribe whenever</div>
      <div class="spacer"></div>
      <!-- Point this action at your newsletter service (Buttondown, ConvertKit, etc.) -->
      <form action="#" method="post" data-subscribe>
        <input type="email" name="email" placeholder="you@domain.com" required aria-label="Email address" />
        <button type="submit">SUBSCRIBE →</button>
      </form>
    </section>
  </div>

  <script>
    // Placeholder subscribe action — replace with a real newsletter endpoint.
    document.querySelector("[data-subscribe]")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const btn = (e.currentTarget as HTMLFormElement).querySelector("button");
      if (btn) btn.textContent = "QUEUED ✓";
    });
  </script>
</Base>
