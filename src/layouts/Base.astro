---
import "../styles/global.css";
import { SITE, DEFAULT_ACCENT, withBase } from "../lib/site.ts";

interface Props {
  title?: string;
  description?: string;
  active?: "about" | "blog" | "projects" | "resources" | "contact";
  ogType?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  active,
  ogType = "website",
} = Astro.props;

// Nav points at the profile page's section anchors so it works from any route.
const nav = [
  { id: "about", label: "about", href: withBase("/#about") },
  { id: "blog", label: "blog", href: withBase("/#writing") },
  { id: "projects", label: "projects", href: withBase("/#projects") },
  { id: "resources", label: "resources", href: withBase("/#resources") },
  { id: "contact", label: "contact", href: withBase("/#contact") },
];

const swatches = [
  { name: "terracotta", color: "#d97757" },
  { name: "blue", color: "#5b8def" },
  { name: "sage", color: "#7c9a76" },
  { name: "violet", color: "#8b7fd9" },
];
---

<!doctype html>
<html lang="en" data-theme="dark" data-accent={DEFAULT_ACCENT}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href={withBase("/images/favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ defaultAccent: DEFAULT_ACCENT }}>
      // Restore theme + accent before first paint (no flash of wrong theme).
      (() => {
        const root = document.documentElement;
        const theme = localStorage.getItem("ibh-theme") || "dark";
        const accent = localStorage.getItem("ibh-accent") || defaultAccent;
        root.setAttribute("data-theme", theme);
        root.setAttribute("data-accent", accent);
      })();
    </script>
  </head>
  <body>
    <header class="topbar">
      <div class="inner">
        <a class="logo" href={withBase("/")}>
          <span class="sigil">~/</span>{SITE.logo}
        </a>

        <nav class="topnav" aria-label="Main">
          {
            nav.map((n) => (
              <a
                href={n.href}
                aria-current={active === n.id ? "page" : undefined}
              >
                {n.label}
              </a>
            ))
          }
        </nav>

        <div class="bar-tools">
          <div class="swatches" role="group" aria-label="Accent color">
            {
              swatches.map((s) => (
                <button
                  class="swatch"
                  data-accent-swatch={s.name}
                  style={`--sw:${s.color}`}
                  title={`accent: ${s.name}`}
                  aria-label={`accent ${s.name}`}
                  aria-pressed="false"
                />
              ))
            }
          </div>
          <button class="icon-btn" data-theme-toggle title="toggle light / dark" aria-label="Toggle theme">☾</button>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <span>© 2026 {SITE.name}</span>
        <span>built in the terminal — not financial advice, just signal</span>
      </div>
    </footer>

    <script>
      const root = document.documentElement;

      // Theme toggle, persisted.
      const themeBtn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
      const syncThemeIcon = () => {
        if (themeBtn)
          themeBtn.textContent =
            root.getAttribute("data-theme") === "light" ? "☀" : "☾";
      };
      syncThemeIcon();
      themeBtn?.addEventListener("click", () => {
        const next = root.getAttribute("data-theme") === "light" ? "dark" : "light";
        root.setAttribute("data-theme", next);
        localStorage.setItem("ibh-theme", next);
        syncThemeIcon();
      });

      // Accent swatches, persisted.
      const swatchBtns =
        document.querySelectorAll<HTMLButtonElement>("[data-accent-swatch]");
      const syncSwatches = () => {
        const current = root.getAttribute("data-accent");
        swatchBtns.forEach((b) =>
          b.setAttribute(
            "aria-pressed",
            b.dataset.accentSwatch === current ? "true" : "false",
          ),
        );
      };
      syncSwatches();
      swatchBtns.forEach((b) =>
        b.addEventListener("click", () => {
          const name = b.dataset.accentSwatch!;
          root.setAttribute("data-accent", name);
          localStorage.setItem("ibh-accent", name);
          syncSwatches();
        }),
      );
    </script>
  </body>
</html>
